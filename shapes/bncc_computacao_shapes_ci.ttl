@prefix bc:   <https://w3id.org/bncc/comp#> .
@prefix bcshci: <https://w3id.org/bncc/comp/shapes/ci#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

bcshci:ShapesCIBNCCComputacao a owl:Ontology ;
    dct:title "Shapes SHACL para CI da ontologia da BNCC Computação"@pt-BR ;
    dct:description "Perfil de validação SHACL com severidades em níveis Info, Warning e Violation para uso em pipelines CI/CD e governança curricular automatizada."@pt-BR ;
    dct:creator "OpenAI - GPT-5.4 Thinking" ;
    dct:language "pt-BR" ;
    dct:source "ontologia_bncc_computacao_inicial.ttl" ;
    dct:created "2026-04-06"^^xsd:date .

#################################################################
# VIOLATION — erros estruturais que devem falhar o pipeline
#################################################################

bcshci:CodigoBNCCUnicoViolationShape a sh:NodeShape ;
    sh:name "Código BNCC único"@pt-BR ;
    sh:description "Todo item normativo codificado deve possuir código BNCC único no grafo."@pt-BR ;
    sh:severity sh:Violation ;
    sh:targetSubjectsOf bc:codigoBNCC ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "O código BNCC deve ser único no grafo; encontrou-se outro recurso com o mesmo código."@pt-BR ;
        sh:select """
            SELECT $this ?value
            WHERE {
              $this bc:codigoBNCC ?value .
              ?other bc:codigoBNCC ?value .
              FILTER(?other != $this)
            }
        """ ;
    ] .

bcshci:ObjetivoAprendizagemEIStructuralShape a sh:NodeShape ;
    sh:name "Objetivo de aprendizagem EI — estrutura mínima"@pt-BR ;
    sh:targetClass bc:ObjetivoAprendizagemEI ;
    sh:property [
        sh:path bc:codigoBNCC ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EI03CO[0-9]{2}$" ;
        sh:message "Objetivos da Educação Infantil devem ter um único código no padrão EI03COxx."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:Eixo ;
        sh:message "Objetivos da Educação Infantil devem estar associados a exatamente um eixo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:pertenceEtapa ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EducacaoInfantil ;
        sh:message "Objetivos da Educação Infantil devem pertencer à etapa Educação Infantil."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:mobilizaProcesso ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ProcessoCognitivo ;
        sh:message "Objetivos da Educação Infantil devem mobilizar ao menos um processo cognitivo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:abordaConceito ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Objetivos da Educação Infantil devem abordar ao menos um conceito computacional."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:temObjetoConhecimento ;
        sh:severity sh:Violation ;
        sh:maxCount 0 ;
        sh:message "Objetivos da Educação Infantil não devem usar bc:temObjetoConhecimento nesta modelagem."@pt-BR ;
    ] .

bcshci:HabilidadeFundamentalStructuralShape a sh:NodeShape ;
    sh:name "Habilidade do Ensino Fundamental — estrutura mínima"@pt-BR ;
    sh:targetClass bc:HabilidadeFundamental ;
    sh:property [
        sh:path bc:codigoBNCC ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EF0[1-9]CO[0-9]{2}$" ;
        sh:message "Habilidades do Ensino Fundamental devem ter um único código no padrão EFxxCOxx."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:Eixo ;
        sh:message "Habilidades do Ensino Fundamental devem estar associadas a exatamente um eixo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:dirigidoA ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:AnoEscolar ;
        sh:message "Habilidades do Ensino Fundamental devem apontar para exatamente um AnoEscolar."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:temObjetoConhecimento ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ObjetoConhecimento ;
        sh:message "Habilidades do Ensino Fundamental devem estar ligadas a pelo menos um objeto de conhecimento."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:pertenceEtapa ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EnsinoFundamental ;
        sh:message "Habilidades do Ensino Fundamental devem pertencer à etapa Ensino Fundamental."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:desdobraCompetencia ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:Competencia ;
        sh:message "Habilidades do Ensino Fundamental devem desdobrar ao menos uma competência do Ensino Fundamental."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:mobilizaProcesso ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ProcessoCognitivo ;
        sh:message "Habilidades do Ensino Fundamental devem mobilizar pelo menos um processo cognitivo."@pt-BR ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Toda habilidade do Ensino Fundamental deve estar ligada a pelo menos um conceito, diretamente ou via objeto de conhecimento."@pt-BR ;
        sh:select """
            SELECT $this
            WHERE {
              FILTER NOT EXISTS { $this bc:abordaConceito ?c . }
              FILTER NOT EXISTS { $this bc:temObjetoConhecimento/bc:representaConceito ?c2 . }
            }
        """ ;
    ] .

bcshci:HabilidadeEnsinoMedioStructuralShape a sh:NodeShape ;
    sh:name "Habilidade do Ensino Médio — estrutura mínima"@pt-BR ;
    sh:targetClass bc:HabilidadeEnsinoMedio ;
    sh:property [
        sh:path bc:codigoBNCC ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EM13CO[0-9]{2}$" ;
        sh:message "Habilidades do Ensino Médio devem ter um único código no padrão EM13COxx."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:dirigidoA ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EnsinoMedioSerie ;
        sh:message "Habilidades do Ensino Médio devem apontar para o segmento EnsinoMedioSerie."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:pertenceEtapa ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EnsinoMedio ;
        sh:message "Habilidades do Ensino Médio devem pertencer à etapa Ensino Médio."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:desdobraCompetencia ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:CompetenciaEspecifica ;
        sh:message "Habilidades do Ensino Médio devem desdobrar ao menos uma competência específica."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:abordaConceito ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Habilidades do Ensino Médio devem abordar ao menos um conceito computacional."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:mobilizaProcesso ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ProcessoCognitivo ;
        sh:message "Habilidades do Ensino Médio devem mobilizar pelo menos um processo cognitivo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:temObjetoConhecimento ;
        sh:severity sh:Violation ;
        sh:maxCount 0 ;
        sh:message "Nesta modelagem inicial, habilidades do Ensino Médio não usam bc:temObjetoConhecimento."@pt-BR ;
    ] .

bcshci:ObjetoConhecimentoStructuralShape a sh:NodeShape ;
    sh:name "Objeto de conhecimento — estrutura mínima"@pt-BR ;
    sh:targetClass bc:ObjetoConhecimento ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:Eixo ;
        sh:message "Todo objeto de conhecimento deve estar associado a exatamente um eixo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:representaConceito ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Todo objeto de conhecimento deve representar pelo menos um conceito computacional."@pt-BR ;
    ] .

bcshci:ConceitoComputacionalStructuralShape a sh:NodeShape ;
    sh:name "Conceito computacional — estrutura mínima"@pt-BR ;
    sh:targetClass bc:ConceitoComputacional ;
    sh:property [
        sh:path skos:inScheme ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:hasValue bc:EsquemaConceitosBNCCComputacao ;
        sh:message "Conceitos computacionais devem pertencer ao esquema de conceitos da BNCC Computação."@pt-BR ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "A relação bc:requerConceito não deve formar ciclos; um conceito não pode requerer a si mesmo via caminho transitivo."@pt-BR ;
        sh:select """
            SELECT $this
            WHERE {
              $this bc:requerConceito+ $this .
            }
        """ ;
    ] .

bcshci:PlanoCurricularStructuralShape a sh:NodeShape ;
    sh:name "Plano curricular — estrutura mínima"@pt-BR ;
    sh:targetClass bc:PlanoCurricular ;
    sh:property [
        sh:path bc:implementaItem ;
        sh:severity sh:Violation ;
        sh:minCount 1 ;
        sh:class bc:ItemNormativo ;
        sh:message "Todo plano curricular deve implementar pelo menos um item normativo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:cobreConceito ;
        sh:severity sh:Violation ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Os conceitos cobertos por um plano curricular devem ser conceitos computacionais."@pt-BR ;
    ] .

#################################################################
# WARNING — inconsistências prováveis, mas nem sempre fatais
#################################################################

bcshci:PrerequisitoExplicitoWarningShape a sh:NodeShape ;
    sh:name "Pré-requisito explícito deve preceder o item"@pt-BR ;
    sh:severity sh:Warning ;
    sh:targetSubjectsOf bc:temPrerequisitoExplicito ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Há pré-requisito explícito sem precedência curricular observável por relação explícita ou heurística do código BNCC."@pt-BR ;
        sh:select """
            PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
            SELECT $this ?pre
            WHERE {
              $this bc:temPrerequisitoExplicito ?pre ;
                    bc:codigoBNCC ?codigoItem .
              ?pre  bc:codigoBNCC ?codigoPre .

              BIND(
                IF(STRSTARTS(STR(?codigoItem), "EI"), 0,
                  IF(STRSTARTS(STR(?codigoItem), "EF"), xsd:integer(SUBSTR(STR(?codigoItem), 3, 2)),
                    IF(STRSTARTS(STR(?codigoItem), "EM"), 100, 999)
                  )
                ) AS ?ordItem
              )
              BIND(
                IF(STRSTARTS(STR(?codigoPre), "EI"), 0,
                  IF(STRSTARTS(STR(?codigoPre), "EF"), xsd:integer(SUBSTR(STR(?codigoPre), 3, 2)),
                    IF(STRSTARTS(STR(?codigoPre), "EM"), 100, 999)
                  )
                ) AS ?ordPre
              )

              FILTER NOT EXISTS { ?pre bc:precedeCurricularmente+ $this . }
              FILTER(?ordPre >= ?ordItem)
            }
        """ ;
    ] .

bcshci:AprofundamentoCompartilhaConceitoWarningShape a sh:NodeShape ;
    sh:name "Aprofundamento deveria compartilhar algum conceito com a base"@pt-BR ;
    sh:severity sh:Warning ;
    sh:targetSubjectsOf bc:aprofunda ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Há relação bc:aprofunda sem conceito compartilhado identificável entre os dois itens."@pt-BR ;
        sh:select """
            SELECT $this ?base
            WHERE {
              $this bc:aprofunda ?base .
              FILTER NOT EXISTS {
                {
                  $this bc:abordaConceito ?c .
                }
                UNION
                {
                  $this bc:temObjetoConhecimento/bc:representaConceito ?c .
                }
                {
                  ?base bc:abordaConceito ?c .
                }
                UNION
                {
                  ?base bc:temObjetoConhecimento/bc:representaConceito ?c .
                }
              }
            }
        """ ;
    ] .

bcshci:PlanoCurricularCoberturaSemSuporteWarningShape a sh:NodeShape ;
    sh:name "Cobertura declarada deve ter suporte em item implementado"@pt-BR ;
    sh:severity sh:Warning ;
    sh:targetClass bc:PlanoCurricular ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Cada conceito declarado em bc:cobreConceito deveria estar suportado por pelo menos um item implementado pelo plano ou por um subconceito correspondente."@pt-BR ;
        sh:select """
            SELECT $this ?conceito
            WHERE {
              $this bc:cobreConceito ?conceito .
              FILTER NOT EXISTS {
                $this bc:implementaItem ?item .
                {
                  ?item bc:abordaConceito ?conceito .
                }
                UNION
                {
                  ?item bc:temObjetoConhecimento/bc:representaConceito ?conceito .
                }
                UNION
                {
                  ?item bc:abordaConceito ?c1 .
                  ?c1 bc:temSubconceito* ?conceito .
                }
                UNION
                {
                  ?item bc:temObjetoConhecimento/bc:representaConceito ?c1 .
                  ?c1 bc:temSubconceito* ?conceito .
                }
              }
            }
        """ ;
    ] .

bcshci:ConceitoOrfaoWarningShape a sh:NodeShape ;
    sh:name "Conceito computacional sem uso curricular"@pt-BR ;
    sh:severity sh:Warning ;
    sh:targetClass bc:ConceitoComputacional ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "O conceito computacional ainda não aparece em nenhuma habilidade, objetivo, objeto de conhecimento ou plano curricular."@pt-BR ;
        sh:select """
            SELECT $this
            WHERE {
              FILTER NOT EXISTS { ?item bc:abordaConceito $this . }
              FILTER NOT EXISTS { ?obj bc:representaConceito $this . }
              FILTER NOT EXISTS { ?plano bc:cobreConceito $this . }
            }
        """ ;
    ] .

#################################################################
# INFO — enriquecimento e higiene semântica
#################################################################

bcshci:ItemNormativoMetadadosInfoShape a sh:NodeShape ;
    sh:name "Item normativo — metadados recomendados"@pt-BR ;
    sh:targetClass bc:ItemNormativo ;
    sh:property [
        sh:path rdfs:label ;
        sh:severity sh:Info ;
        sh:minCount 1 ;
        sh:message "É recomendável fornecer rdfs:label para facilitar inspeção humana e debug em pipeline."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:textoNormativo ;
        sh:severity sh:Info ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "É recomendável manter bc:textoNormativo para rastreabilidade com o documento-base."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:paginaFonte ;
        sh:severity sh:Info ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "É recomendável manter bc:paginaFonte para auditoria documental."@pt-BR ;
    ] .

bcshci:ConceitoComputacionalInfoShape a sh:NodeShape ;
    sh:name "Conceito computacional — rótulos SKOS recomendados"@pt-BR ;
    sh:targetClass bc:ConceitoComputacional ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:severity sh:Info ;
        sh:minCount 1 ;
        sh:message "É recomendável fornecer skos:prefLabel para todos os conceitos computacionais."@pt-BR ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:severity sh:Info ;
        sh:minCount 1 ;
        sh:message "É recomendável fornecer rdfs:label para consumo em ferramentas gerais RDF."@pt-BR ;
    ] .

bcshci:HabilidadeFundamentalMaterializacaoInfoShape a sh:NodeShape ;
    sh:name "Habilidade do Ensino Fundamental — materialização explícita de conceitos"@pt-BR ;
    sh:severity sh:Info ;
    sh:targetClass bc:HabilidadeFundamental ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "A habilidade já possui objeto de conhecimento, mas não materializa bc:abordaConceito explicitamente; materializar pode simplificar analytics e queries em CI."@pt-BR ;
        sh:select """
            SELECT $this
            WHERE {
              $this bc:temObjetoConhecimento/bc:representaConceito ?c .
              FILTER NOT EXISTS { $this bc:abordaConceito ?c2 . }
            }
        """ ;
    ] .
