@prefix bc:   <https://w3id.org/bncc/comp#> .
@prefix bcsh: <https://w3id.org/bncc/comp/shapes#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

bcsh:ShapesComplementaresBNCCComputacao a owl:Ontology ;
    dct:title "Shapes SHACL complementares para a ontologia da BNCC Computação"@pt-BR ;
    dct:description "Conjunto inicial de shapes SHACL Core e SHACL-SPARQL para validar estrutura curricular, consistência mínima de progressão, coerência de cobertura e alinhamento sintático dos códigos BNCC na ontologia inicial da BNCC Computação."@pt-BR ;
    dct:creator "OpenAI - GPT-5.4 Thinking" ;
    dct:language "pt-BR" ;
    dct:source "ontologia_bncc_computacao_inicial.ttl" ;
    dct:created "2026-04-07"^^xsd:date .

bcsh:CodigoBNCCUnicoShape a sh:NodeShape ;
    sh:name "Unicidade de código BNCC"@pt-BR ;
    sh:description "Todo item normativo codificado deve possuir código BNCC único no grafo."@pt-BR ;
    sh:targetSubjectsOf bc:codigoBNCC ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "O código BNCC deve ser único no grafo; encontrou-se outro recurso com o mesmo código."@pt-BR ;
        sh:select """
            SELECT $this ?value
            WHERE {
              $this bc:codigoBNCC ?value .
              ?other bc:codigoBNCC ?value .
              FILTER(?other != $this)
            }
        """ ;
    ] .

bcsh:ObjetivoAprendizagemEIShape a sh:NodeShape ;
    sh:name "Objetivo de aprendizagem da Educação Infantil"@pt-BR ;
    sh:targetClass bc:ObjetivoAprendizagemEI ;
    sh:property [
        sh:path bc:codigoBNCC ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EI03CO[0-9]{2}$" ;
        sh:message "Objetivos da Educação Infantil devem ter um único código no padrão EI03COxx."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:Eixo ;
        sh:message "Objetivos da Educação Infantil devem estar associados a exatamente um eixo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:pertenceEtapa ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EducacaoInfantil ;
        sh:message "Objetivos da Educação Infantil devem pertencer à etapa Educação Infantil."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:mobilizaProcesso ;
        sh:minCount 1 ;
        sh:class bc:ProcessoCognitivo ;
        sh:message "Objetivos da Educação Infantil devem mobilizar ao menos um processo cognitivo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:abordaConceito ;
        sh:minCount 1 ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Objetivos da Educação Infantil devem abordar ao menos um conceito computacional."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:temObjetoConhecimento ;
        sh:maxCount 0 ;
        sh:message "Objetivos da Educação Infantil não devem usar bc:temObjetoConhecimento nesta modelagem."@pt-BR ;
    ] .

bcsh:HabilidadeFundamentalShape a sh:NodeShape ;
    sh:name "Habilidade do Ensino Fundamental"@pt-BR ;
    sh:targetClass bc:HabilidadeFundamental ;
    sh:property [
        sh:path bc:codigoBNCC ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EF0[1-9]CO[0-9]{2}$" ;
        sh:message "Habilidades do Ensino Fundamental devem ter um único código no padrão EFxxCOxx."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:Eixo ;
        sh:message "Habilidades do Ensino Fundamental devem estar associadas a exatamente um eixo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:dirigidoA ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:AnoEscolar ;
        sh:message "Habilidades do Ensino Fundamental devem apontar para exatamente um AnoEscolar."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:temObjetoConhecimento ;
        sh:minCount 1 ;
        sh:class bc:ObjetoConhecimento ;
        sh:message "Habilidades do Ensino Fundamental devem estar ligadas a pelo menos um objeto de conhecimento."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:pertenceEtapa ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EnsinoFundamental ;
        sh:message "Habilidades do Ensino Fundamental devem pertencer à etapa Ensino Fundamental."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:desdobraCompetencia ;
        sh:minCount 1 ;
        sh:class bc:Competencia ;
        sh:message "Habilidades do Ensino Fundamental devem desdobrar ao menos uma competência do Ensino Fundamental."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:mobilizaProcesso ;
        sh:minCount 1 ;
        sh:class bc:ProcessoCognitivo ;
        sh:message "Habilidades do Ensino Fundamental devem mobilizar pelo menos um processo cognitivo."@pt-BR ;
    ] .

bcsh:HabilidadeEnsinoMedioShape a sh:NodeShape ;
    sh:name "Habilidade do Ensino Médio"@pt-BR ;
    sh:targetClass bc:HabilidadeEnsinoMedio ;
    sh:property [
        sh:path bc:codigoBNCC ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^EM13CO[0-9]{2}$" ;
        sh:message "Habilidades do Ensino Médio devem ter um único código no padrão EM13COxx."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:dirigidoA ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EnsinoMedioSerie ;
        sh:message "Habilidades do Ensino Médio devem apontar para o segmento EnsinoMedioSerie."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:pertenceEtapa ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue bc:EnsinoMedio ;
        sh:message "Habilidades do Ensino Médio devem pertencer à etapa Ensino Médio."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:desdobraCompetencia ;
        sh:minCount 1 ;
        sh:class bc:CompetenciaEspecifica ;
        sh:message "Habilidades do Ensino Médio devem desdobrar ao menos uma competência específica."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:abordaConceito ;
        sh:minCount 1 ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Habilidades do Ensino Médio devem abordar ao menos um conceito computacional."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:mobilizaProcesso ;
        sh:minCount 1 ;
        sh:class bc:ProcessoCognitivo ;
        sh:message "Habilidades do Ensino Médio devem mobilizar pelo menos um processo cognitivo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:temObjetoConhecimento ;
        sh:maxCount 0 ;
        sh:message "Nesta modelagem inicial, habilidades do Ensino Médio não usam bc:temObjetoConhecimento."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:maxCount 0 ;
        sh:message "Nesta modelagem inicial, habilidades do Ensino Médio não são vinculadas diretamente aos eixos do Fundamental."@pt-BR ;
    ] .

bcsh:ObjetoConhecimentoShape a sh:NodeShape ;
    sh:name "Objeto de conhecimento"@pt-BR ;
    sh:targetClass bc:ObjetoConhecimento ;
    sh:property [
        sh:path bc:associadoAEixo ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class bc:Eixo ;
        sh:message "Todo objeto de conhecimento deve estar associado a exatamente um eixo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:representaConceito ;
        sh:minCount 1 ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Todo objeto de conhecimento deve representar pelo menos um conceito computacional."@pt-BR ;
    ] .

bcsh:ConceitoComputacionalShape a sh:NodeShape ;
    sh:name "Conceito computacional"@pt-BR ;
    sh:targetClass bc:ConceitoComputacional ;
    sh:property [
        sh:path skos:inScheme ;
        sh:minCount 1 ;
        sh:hasValue bc:EsquemaConceitosBNCCComputacao ;
        sh:message "Conceitos computacionais devem pertencer ao esquema de conceitos da BNCC Computação."@pt-BR ;
    ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Conceitos computacionais devem possuir skos:prefLabel."@pt-BR ;
    ] .

bcsh:PlanoCurricularShape a sh:NodeShape ;
    sh:name "Plano curricular"@pt-BR ;
    sh:targetClass bc:PlanoCurricular ;
    sh:property [
        sh:path bc:implementaItem ;
        sh:minCount 1 ;
        sh:class bc:ItemNormativo ;
        sh:message "Todo plano curricular deve implementar pelo menos um item normativo."@pt-BR ;
    ] ;
    sh:property [
        sh:path bc:cobreConceito ;
        sh:class bc:ConceitoComputacional ;
        sh:message "Os conceitos cobertos por um plano curricular devem ser conceitos computacionais."@pt-BR ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Cada conceito declarado em bc:cobreConceito deve estar suportado por pelo menos um item implementado pelo plano."@pt-BR ;
        sh:select """
            SELECT $this ?conceito
            WHERE {
              $this bc:cobreConceito ?conceito .
              FILTER NOT EXISTS {
                $this bc:implementaItem ?item .
                {
                  ?item bc:abordaConceito ?conceito .
                }
                UNION
                {
                  ?item bc:temObjetoConhecimento/bc:representaConceito ?conceito .
                }
                UNION
                {
                  ?item bc:abordaConceito ?c1 .
                  ?c1 bc:temSubconceito* ?conceito .
                }
                UNION
                {
                  ?item bc:temObjetoConhecimento/bc:representaConceito ?c1 .
                  ?c1 bc:temSubconceito* ?conceito .
                }
              }
            }
        """ ;
    ] .

bcsh:AprofundamentoConsistenteShape a sh:NodeShape ;
    sh:name "Consistência mínima de aprofundamento"@pt-BR ;
    sh:targetSubjectsOf bc:aprofunda ;
    sh:severity sh:Warning ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Quando um item aprofunda outro, recomenda-se que compartilhem pelo menos um conceito abordado."@pt-BR ;
        sh:select """
            SELECT $this ?base
            WHERE {
              $this bc:aprofunda ?base .
              FILTER NOT EXISTS {
                $this bc:abordaConceito ?c .
                ?base bc:abordaConceito ?c .
              }
            }
        """ ;
    ] .

bcsh:PrecedenciaAcilicaDiretaShape a sh:NodeShape ;
    sh:name "Precedência direta sem ciclos triviais"@pt-BR ;
    sh:targetSubjectsOf bc:precedeCurricularmente ;
    sh:severity sh:Violation ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Não deve haver precedência curricular direta em ambos os sentidos entre o mesmo par de itens."@pt-BR ;
        sh:select """
            SELECT $this ?other
            WHERE {
              $this bc:precedeCurricularmente ?other .
              ?other bc:precedeCurricularmente $this .
            }
        """ ;
    ] .

bcsh:PrerequisitoExplicitoCoerenteShape a sh:NodeShape ;
    sh:name "Pré-requisito explícito coerente"@pt-BR ;
    sh:targetSubjectsOf bc:temPrerequisitoExplicito ;
    sh:severity sh:Warning ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Recomenda-se que um pré-requisito explícito também possua uma relação de precedência curricular direta ou indireta para o item dependente."@pt-BR ;
        sh:select """
            SELECT $this ?pre
            WHERE {
              $this bc:temPrerequisitoExplicito ?pre .
              FILTER NOT EXISTS { ?pre bc:precedeCurricularmente+ $this }
            }
        """ ;
    ] .
