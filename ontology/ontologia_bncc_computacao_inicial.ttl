bc:EF01CO03 a bc:HabilidadeFundamental ;
    rdfs:label "EF01CO03"@pt-BR ;
    bc:abordaConceito bc:Algoritmo,
        bc:Sequenciamento ;
    bc:associadoAEixo bc:PensamentoComputacional ;
    bc:codigoBNCC "EF01CO03"^^xsd:string ;
    bc:desdobraCompetencia bc:EFComp4 ;
    bc:dirigidoA bc:Ano1EF ;
    bc:mobilizaProcesso bc:Criar ;
    bc:paginaFonte 12 ;
    bc:pertenceEtapa bc:EnsinoFundamental ;
    bc:precedeCurricularmente bc:EF02CO02 ;
    bc:temObjetoConhecimento bc:ConceituacaoDeAlgoritmos ;
    bc:textoNormativo "Reorganizar e criar sequências de passos em meios físicos ou digitais, relacionando essas sequências à palavra ‘Algoritmos’."^^xsd:string .

bc:EF03CO02 a bc:HabilidadeFundamental ;
    rdfs:label "EF03CO02"@pt-BR ;
    bc:abordaConceito bc:Algoritmo,
        bc:RepeticaoCondicional,
        bc:Selecao ;
    bc:aprofunda bc:EF02CO02 ;
    bc:associadoAEixo bc:PensamentoComputacional ;
    bc:codigoBNCC "EF03CO02"^^xsd:string ;
    bc:desdobraCompetencia bc:EFComp4 ;
    bc:dirigidoA bc:Ano3EF ;
    bc:mobilizaProcesso bc:Criar ;
    bc:paginaFonte 18 ;
    bc:pertenceEtapa bc:EnsinoFundamental ;
    bc:precedeCurricularmente bc:EF06CO02 ;
    bc:temObjetoConhecimento bc:AlgoritmosComRepeticoesCondicionaisSimples ;
    bc:textoNormativo "Criar e simular algoritmos representados em linguagem oral, escrita ou pictográfica, que incluam sequências e repetições simples com condição (iterações indefinidas), para resolver problemas de forma independente e em colaboração."^^xsd:string .

bc:EF06CO02 a bc:HabilidadeFundamental ;
    rdfs:label "EF06CO02"@pt-BR ;
    rdfs:comment "Esta habilidade marca a transição explícita para o uso de linguagem de programação no Ensino Fundamental."@pt-BR ;
    bc:abordaConceito bc:LinguagemDeProgramacao,
        bc:Programacao,
        bc:RepeticaoSimples,
        bc:Selecao,
        bc:Sequenciamento ;
    bc:aprofunda bc:EF03CO02 ;
    bc:associadoAEixo bc:PensamentoComputacional ;
    bc:codigoBNCC "EF06CO02"^^xsd:string ;
    bc:desdobraCompetencia bc:EFComp4 ;
    bc:dirigidoA bc:Ano6EF ;
    bc:mobilizaProcesso bc:Elaborar ;
    bc:paginaFonte 38 ;
    bc:pertenceEtapa bc:EnsinoFundamental ;
    bc:precedeCurricularmente bc:EM13CO03,
        bc:EM13CO04 ;
    bc:temObjetoConhecimento bc:LinguagemDeProgramacaoOK ;
    bc:temPrerequisitoExplicito bc:EF03CO02 ;
    bc:textoNormativo "Elaborar algoritmos que envolvam instruções sequenciais, de repetição e de seleção usando uma linguagem de programação."^^xsd:string .

bc:EF08CO08 a bc:HabilidadeFundamental ;
    rdfs:label "EF08CO08"@pt-BR ;
    bc:abordaConceito bc:DadosPessoais,
        bc:Privacidade ;
    bc:associadoAEixo bc:CulturaDigital ;
    bc:codigoBNCC "EF08CO08"^^xsd:string ;
    bc:desdobraCompetencia bc:EFComp2 ;
    bc:dirigidoA bc:Ano8EF ;
    bc:mobilizaProcesso bc:Distinguir ;
    bc:paginaFonte 50 ;
    bc:pertenceEtapa bc:EnsinoFundamental ;
    bc:precedeCurricularmente bc:EM13CO08 ;
    bc:temObjetoConhecimento bc:RedesSociaisESegurancaDaInformacao ;
    bc:textoNormativo "Distinguir os tipos de dados pessoais que são solicitados em espaços digitais e os riscos associados."^^xsd:string .

bc:EFComp1 a bc:Competencia ;
    rdfs:label "Competência 1 do Ensino Fundamental"@pt-BR ;
    bc:paginaFonte 11 ;
    bc:pertenceEtapa bc:EnsinoFundamental ;
    bc:textoNormativo "Compreender a Computação como uma área de conhecimento que contribui para explicar o mundo atual e ser um agente ativo e consciente de transformação capaz de analisar criticamente seus impactos sociais, ambientais, culturais, econômicos, científicos, tecnológicos, legais e éticos."^^xsd:string .

bc:EFComp6 a bc:Competencia ;
    rdfs:label "Competência 6 do Ensino Fundamental"@pt-BR ;
    bc:paginaFonte 11 ;
    bc:pertenceEtapa bc:EnsinoFundamental ;
    bc:textoNormativo "Desenvolver projetos, baseados em problemas, desafios e oportunidades que façam sentido ao contexto ou interesse do estudante, de maneira individual e/ou cooperativa, fazendo uso da Computação e suas tecnologias, utilizando conceitos, técnicas e ferramentas computacionais que possibilitem automatizar processos em diversas áreas do conhecimento com base em princípios éticos, democráticos, sustentáveis e solidários, valorizando a diversidade de indivíduos e de grupos sociais, de maneira inclusiva."^^xsd:string .

bc:EMCE3 a bc:CompetenciaEspecifica ;
    rdfs:label "Competência específica 3 do Ensino Médio"@pt-BR ;
    bc:paginaFonte 64 ;
    bc:pertenceEtapa bc:EnsinoMedio ;
    bc:textoNormativo "Analisar situações do mundo contemporâneo, selecionando técnicas computacionais apropriadas para a solução de problemas."^^xsd:string .

