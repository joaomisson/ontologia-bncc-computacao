PREFIX bc: <https://w3id.org/bncc/comp#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Parâmetros:
#   VALUES (?anoSel ?eixoSel ?conceitoSel) { (bc:Ano8EF bc:CulturaDigital UNDEF) }
SELECT ?anoSel ?eixoSel ?conceitoBase ?labelConceito
       (COUNT(DISTINCT ?item) AS ?qtdItens)
       (GROUP_CONCAT(DISTINCT ?codigo; separator=", ") AS ?codigos)
WHERE {
  VALUES (?anoSel ?eixoSel ?conceitoSel) { (bc:Ano8EF bc:CulturaDigital UNDEF) }

  ?item bc:codigoBNCC ?codigo .
  FILTER(!BOUND(?anoSel) || EXISTS { ?item bc:dirigidoA ?anoSel })
  FILTER(!BOUND(?eixoSel) || EXISTS { ?item bc:associadoAEixo ?eixoSel })

  {
    ?item bc:abordaConceito ?conceitoBase .
  }
  UNION
  {
    ?item bc:temObjetoConhecimento/bc:representaConceito ?conceitoBase .
  }

  FILTER(!BOUND(?conceitoSel) || ?conceitoBase = ?conceitoSel || EXISTS { ?conceitoBase bc:temSubconceito* ?conceitoSel })

  OPTIONAL { ?conceitoBase rdfs:label ?labelConceito }
}
GROUP BY ?anoSel ?eixoSel ?conceitoBase ?labelConceito
ORDER BY ?labelConceito ?conceitoBase
