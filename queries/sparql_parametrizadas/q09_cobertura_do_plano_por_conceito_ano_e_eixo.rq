PREFIX bc: <https://w3id.org/bncc/comp#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Parâmetros:
#   VALUES (?planoSel ?conceitoSel ?anoSel ?eixoSel) { (bc:PlanoExemploSegurancaEF8 bc:Privacidade bc:Ano8EF bc:CulturaDigital) }
SELECT DISTINCT ?planoSel ?conceitoSel ?labelConceito ?item ?codigo ?origemCobertura ?texto
WHERE {
  VALUES (?planoSel ?conceitoSel ?anoSel ?eixoSel) { (bc:PlanoExemploSegurancaEF8 bc:Privacidade bc:Ano8EF bc:CulturaDigital) }

  OPTIONAL { ?conceitoSel rdfs:label ?labelConceito }

  {
    ?planoSel bc:implementaItem ?item .
    {
      ?item bc:abordaConceito ?c .
    }
    UNION
    {
      ?item bc:temObjetoConhecimento/bc:representaConceito ?c .
    }
    FILTER(?c = ?conceitoSel || EXISTS { ?c bc:temSubconceito* ?conceitoSel })
    BIND("item implementado"@pt-BR AS ?origemCobertura)
  }
  UNION
  {
    ?planoSel bc:cobreConceito ?cob .
    FILTER(?cob = ?conceitoSel || EXISTS { ?cob bc:temSubconceito* ?conceitoSel })
    BIND(?planoSel AS ?item)
    BIND("cobertura declarada"@pt-BR AS ?origemCobertura)
  }

  OPTIONAL { ?item bc:codigoBNCC ?codigo }
  OPTIONAL { ?item bc:textoNormativo ?texto }

  FILTER(!BOUND(?anoSel) || !isIRI(?item) || EXISTS { ?item bc:dirigidoA ?anoSel })
  FILTER(!BOUND(?eixoSel) || !isIRI(?item) || EXISTS { ?item bc:associadoAEixo ?eixoSel })
}
ORDER BY ?origemCobertura ?codigo
