PREFIX bc: <https://w3id.org/bncc/comp#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# Altere o conceito em VALUES para outro conceito computacional de interesse.
SELECT DISTINCT ?conceito ?labelConceito ?item ?codigo ?etapa ?escopo ?processo ?texto
WHERE {
  VALUES ?conceito { bc:Algoritmo }

  {
    ?item bc:abordaConceito ?conceito .
  }
  UNION
  {
    ?item bc:temObjetoConhecimento/bc:representaConceito ?conceito .
  }

  OPTIONAL { ?conceito rdfs:label ?labelConceito }
  OPTIONAL { ?item bc:codigoBNCC ?codigo }
  OPTIONAL { ?item bc:pertenceEtapa ?etapa }
  OPTIONAL { ?item bc:dirigidoA ?escopo }
  OPTIONAL { ?item bc:mobilizaProcesso ?processo }
  OPTIONAL { ?item bc:textoNormativo ?texto }

  BIND(
    IF(BOUND(?codigo),
      IF(STRSTARTS(STR(?codigo), "EI"), 0,
        IF(STRSTARTS(STR(?codigo), "EF"), xsd:integer(SUBSTR(STR(?codigo), 3, 2)),
          IF(STRSTARTS(STR(?codigo), "EM"), 100, 999)
        )
      ),
      999
    ) AS ?ord
  )
}
ORDER BY ?ord ?codigo ?item
