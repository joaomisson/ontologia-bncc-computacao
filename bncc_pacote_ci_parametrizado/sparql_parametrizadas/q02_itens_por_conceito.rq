PREFIX bc: <https://w3id.org/bncc/comp#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Parâmetros:
#   VALUES (?conceitoSel ?anoSel ?eixoSel) { (bc:Algoritmo UNDEF UNDEF) }
SELECT DISTINCT ?conceitoSel ?labelConceito ?item ?codigo ?escopo ?eixo ?origemConceito ?texto
WHERE {
  VALUES (?conceitoSel ?anoSel ?eixoSel) { (bc:Algoritmo UNDEF UNDEF) }

  {
    ?item bc:abordaConceito ?conceitoSel .
    BIND("direto"@pt-BR AS ?origemConceito)
  }
  UNION
  {
    ?item bc:temObjetoConhecimento/bc:representaConceito ?conceitoSel .
    BIND("via objeto de conhecimento"@pt-BR AS ?origemConceito)
  }

  OPTIONAL { ?conceitoSel rdfs:label ?labelConceito }
  OPTIONAL { ?item bc:codigoBNCC ?codigo }
  OPTIONAL { ?item bc:dirigidoA ?escopo }
  OPTIONAL { ?item bc:associadoAEixo ?eixo }
  OPTIONAL { ?item bc:textoNormativo ?texto }

  FILTER(!BOUND(?anoSel) || EXISTS { ?item bc:dirigidoA ?anoSel })
  FILTER(!BOUND(?eixoSel) || EXISTS { ?item bc:associadoAEixo ?eixoSel })
}
ORDER BY ?codigo ?origemConceito
