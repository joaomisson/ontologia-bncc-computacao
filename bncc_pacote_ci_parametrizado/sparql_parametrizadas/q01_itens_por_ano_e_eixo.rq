PREFIX bc: <https://w3id.org/bncc/comp#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Parâmetros:
# - Troque os valores em VALUES.
# - Use UNDEF para desabilitar um filtro.
# Exemplo:
#   VALUES (?anoSel ?eixoSel) { (bc:Ano8EF bc:CulturaDigital) }
SELECT DISTINCT ?item ?codigo ?tipo ?escopo ?eixo ?objetoConhecimento ?label ?texto
WHERE {
  VALUES (?anoSel ?eixoSel) { (bc:Ano8EF bc:CulturaDigital) }

  ?item bc:codigoBNCC ?codigo ;
        a ?tipo .

  OPTIONAL { ?item rdfs:label ?label }
  OPTIONAL { ?item bc:textoNormativo ?texto }
  OPTIONAL { ?item bc:dirigidoA ?escopo }
  OPTIONAL { ?item bc:associadoAEixo ?eixo }
  OPTIONAL { ?item bc:temObjetoConhecimento ?objetoConhecimento }

  FILTER(!BOUND(?anoSel) || EXISTS { ?item bc:dirigidoA ?anoSel })
  FILTER(!BOUND(?eixoSel) || EXISTS { ?item bc:associadoAEixo ?eixoSel })
}
ORDER BY ?codigo ?item
