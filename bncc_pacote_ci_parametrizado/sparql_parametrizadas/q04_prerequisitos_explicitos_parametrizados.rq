PREFIX bc: <https://w3id.org/bncc/comp#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Parâmetros:
#   VALUES (?anoSel ?eixoSel ?conceitoSel) { (bc:Ano8EF bc:CulturaDigital UNDEF) }
SELECT DISTINCT ?item ?codigo ?prerequisito ?codigoPrerequisito ?eixo ?escopo ?conceitoSel ?labelItem ?labelPrerequisito
WHERE {
  VALUES (?anoSel ?eixoSel ?conceitoSel) { (bc:Ano8EF bc:CulturaDigital UNDEF) }

  ?item bc:temPrerequisitoExplicito ?prerequisito ;
        bc:codigoBNCC ?codigo .
  ?prerequisito bc:codigoBNCC ?codigoPrerequisito .

  OPTIONAL { ?item rdfs:label ?labelItem }
  OPTIONAL { ?prerequisito rdfs:label ?labelPrerequisito }
  OPTIONAL { ?item bc:associadoAEixo ?eixo }
  OPTIONAL { ?item bc:dirigidoA ?escopo }

  FILTER(!BOUND(?anoSel) || EXISTS { ?item bc:dirigidoA ?anoSel })
  FILTER(!BOUND(?eixoSel) || EXISTS { ?item bc:associadoAEixo ?eixoSel })
  FILTER(
    !BOUND(?conceitoSel)
    || EXISTS { ?item bc:abordaConceito ?conceitoSel }
    || EXISTS { ?item bc:temObjetoConhecimento/bc:representaConceito ?conceitoSel }
  )
}
ORDER BY ?codigo ?codigoPrerequisito
